  update)      shift; cmd_update "$@" ;;
  help|--help|-h) cmd_help ;;
  version|--version|-v) echo "Hermes v$VERSION ($CODENAME)" ;;
  *)           err "Unknown command: $1"; cmd_help ;;
esac
