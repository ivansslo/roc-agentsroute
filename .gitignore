# ══════════════════════════════════════════════════
# .gitignore — roc-agentsroute
# ══════════════════════════════════════════════════

# ─── Secrets & Keys ──────────────────────────────
.keys
*.keys
config.env
.env
.env.*
!.env.example

# ─── Hermes Data ─────────────────────────────────
.hermes/
chat_history.json
chat_*.json

# ─── Python ──────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.venv/
venv/
python3_venv/

# ─── Node ────────────────────────────────────────
node_modules/

# ─── OS / Editor ─────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ─── Logs ────────────────────────────────────────
*.log
npm-debug.log*

# ─── Firebase / Google Credentials ─────────────
assets/GoogleService-Info.plist
GoogleService-Info.plist
google-services.json

# ─── Backups / Patch artifacts ───────────────────
*.bak
*.bak.*
hermes.bak.*
fix_hermes.py
